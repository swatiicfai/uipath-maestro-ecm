<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:uipath="http://uipath.org/schema/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="FieldIncidentTriage-diagram" targetNamespace="http://www.omg.org/spec/BPMN/20100524/MODEL" exporter="forenly/uipath-maestro-ecm" exporterVersion="1.1">
  <bpmn:process id="Process_FieldIncidentTriage" name="Field Incident Triage" isExecutable="false">
    <bpmn:documentation>Physical AI field-inspection incident triage. A robot-fleet vision system (e.g. Solomon SolVision) detects a defect; the incident is dequeued from the IncidentReports queue, triaged by the Vision AI Analyst (category / riskScore / confidence), then run through Impact Analysis which estimates the economic (repair + downtime + inaction risk) and organizational (roles engaged / scope / safety) impact. The routing gateway escalates costly, safety-critical, or fleet-wide defects to the Incident Review Board via Action Center (HITL); the rest are auto-resolved on the Fast Track.</bpmn:documentation>
    <bpmn:extensionElements>
      <uipath:variables version="v1">
        <uipath:input id="vIncident" name="Incident" type="jsonSchema" elementId="Event_start" default="{&#34;incidentId&#34;:&#34;&#34;,&#34;category&#34;:&#34;&#34;,&#34;riskScore&#34;:0,&#34;confidence&#34;:0,&#34;hitlRequired&#34;:false,&#34;suggestedAction&#34;:&#34;&#34;,&#34;route&#34;:&#34;&#34;,&#34;economicImpactScore&#34;:0,&#34;estimatedCostUsd&#34;:0,&#34;orgScope&#34;:&#34;&#34;,&#34;safetyCritical&#34;:false}"><![CDATA[{"type":"object","$schema":"http://json-schema.org/draft-07/schema#","properties":{"incidentId":{"type":"string"},"category":{"type":"string"},"riskScore":{"type":"number"},"confidence":{"type":"number"},"hitlRequired":{"type":"boolean"},"suggestedAction":{"type":"string"},"route":{"type":"string"},"economicImpactScore":{"type":"number"},"estimatedCostUsd":{"type":"number"},"orgScope":{"type":"string"},"safetyCritical":{"type":"boolean"}}}]]></uipath:input>
        <uipath:inputOutput id="vIncidentIO" name="Incident" type="jsonSchema" elementId="Event_start"><![CDATA[{"type":"object","$schema":"http://json-schema.org/draft-07/schema#","properties":{"incidentId":{"type":"string"},"category":{"type":"string"},"riskScore":{"type":"number"},"confidence":{"type":"number"},"hitlRequired":{"type":"boolean"},"suggestedAction":{"type":"string"},"route":{"type":"string"},"economicImpactScore":{"type":"number"},"estimatedCostUsd":{"type":"number"},"orgScope":{"type":"string"},"safetyCritical":{"type":"boolean"}}}]]></uipath:inputOutput>
      </uipath:variables>
    </bpmn:extensionElements>

    <bpmn:startEvent id="Event_start" name="Field Incident Captured">
      <bpmn:extensionElements>
        <uipath:entryPointId value="a1b2c3d4-0001-4a00-8000-000000000001" />
        <uipath:mapping version="v1">
          <uipath:type value="BPMN.Variables" version="v1" />
          <uipath:output name="Incident" type="json" source="=vars.vIncident" var="vIncidentIO" />
        </uipath:mapping>
      </bpmn:extensionElements>
      <bpmn:outgoing>edge_start-triage</bpmn:outgoing>
    </bpmn:startEvent>

    <bpmn:serviceTask id="Activity_triage" name="AI Triage and Risk Score">
      <bpmn:documentation>Role: AI Analyst. Vision AI Analyst scores the incident (category / riskScore / confidence) and sets hitlRequired. Maps to run_pipeline.py analyst stage.</bpmn:documentation>
      <bpmn:incoming>edge_start-triage</bpmn:incoming>
      <bpmn:outgoing>edge_triage-reproduce</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:task id="Activity_reproduce" name="Reproduce Incident">
      <bpmn:documentation>Role: AI Analyst. Replay sensor/log capture to confirm the fault is reproducible.</bpmn:documentation>
      <bpmn:incoming>edge_triage-reproduce</bpmn:incoming>
      <bpmn:outgoing>edge_reproduce-rootcause</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Activity_rootcause" name="Analyze Root Cause">
      <bpmn:documentation>Role: AI Analyst. Determine the root cause category driving the routing decision.</bpmn:documentation>
      <bpmn:incoming>edge_reproduce-rootcause</bpmn:incoming>
      <bpmn:outgoing>edge_rootcause-review</bpmn:outgoing>
    </bpmn:task>

    <bpmn:task id="Activity_review" name="Incident Review">
      <bpmn:documentation>Role: Incident Review Board. Consolidate triage + root cause before impact analysis.</bpmn:documentation>
      <bpmn:incoming>edge_rootcause-review</bpmn:incoming>
      <bpmn:outgoing>edge_review-impact</bpmn:outgoing>
    </bpmn:task>

    <bpmn:serviceTask id="Activity_impact" name="Impact Analysis (Economic + Organizational)">
      <bpmn:documentation>Role: AI Analyst. Estimates economic impact (repair + downtime + inaction risk -> economicImpactScore, estimatedCostUsd) and organizational impact (rolesEngaged, orgScope, safetyCritical, leadTimeDays). Sets the authoritative hitlRequired/route consumed by the gateway. Maps to agents/impact_agent.py.</bpmn:documentation>
      <bpmn:incoming>edge_review-impact</bpmn:incoming>
      <bpmn:outgoing>edge_impact-gateway</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:exclusiveGateway id="Gateway_hitl" name="HITL Required?" default="edge_gateway-autoresolve">
      <bpmn:documentation>Routes on impact, not risk alone: hitlRequired = analyst-flagged OR economicImpactScore >= 0.40 OR safetyCritical OR orgScope = FLEET_WIDE.</bpmn:documentation>
      <bpmn:incoming>edge_impact-gateway</bpmn:incoming>
      <bpmn:outgoing>edge_gateway-actioncenter</bpmn:outgoing>
      <bpmn:outgoing>edge_gateway-autoresolve</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:userTask id="Activity_actioncenter" name="Escalate to Review Board (Action Center)">
      <bpmn:documentation>Role: Incident Review Board (HITL). High-impact incidents (costly / safety-critical / fleet-wide) become an Action Center task for human approval before any field change. The reviewer sees estimatedCostUsd, rolesEngaged, and hitlReason.</bpmn:documentation>
      <bpmn:incoming>edge_gateway-actioncenter</bpmn:incoming>
      <bpmn:outgoing>edge_actioncenter-escalated</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:serviceTask id="Activity_autoresolve" name="Fast-Track Auto-Resolve">
      <bpmn:documentation>Role: AI Analyst. Low-impact incidents (cheap, contained, no safety flag) are resolved autonomously without human review.</bpmn:documentation>
      <bpmn:incoming>edge_gateway-autoresolve</bpmn:incoming>
      <bpmn:outgoing>edge_autoresolve-resolved</bpmn:outgoing>
    </bpmn:serviceTask>

    <bpmn:endEvent id="Event_escalated" name="Escalated to Review Board">
      <bpmn:incoming>edge_actioncenter-escalated</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:endEvent id="Event_resolved" name="Auto-Resolved">
      <bpmn:incoming>edge_autoresolve-resolved</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="edge_start-triage" sourceRef="Event_start" targetRef="Activity_triage" />
    <bpmn:sequenceFlow id="edge_triage-reproduce" sourceRef="Activity_triage" targetRef="Activity_reproduce" />
    <bpmn:sequenceFlow id="edge_reproduce-rootcause" sourceRef="Activity_reproduce" targetRef="Activity_rootcause" />
    <bpmn:sequenceFlow id="edge_rootcause-review" sourceRef="Activity_rootcause" targetRef="Activity_review" />
    <bpmn:sequenceFlow id="edge_review-impact" sourceRef="Activity_review" targetRef="Activity_impact" />
    <bpmn:sequenceFlow id="edge_impact-gateway" sourceRef="Activity_impact" targetRef="Gateway_hitl" />
    <bpmn:sequenceFlow id="edge_gateway-actioncenter" name="high impact" sourceRef="Gateway_hitl" targetRef="Activity_actioncenter">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">=vars.vIncidentIO.hitlRequired.Equals(true)</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="edge_gateway-autoresolve" name="low impact" sourceRef="Gateway_hitl" targetRef="Activity_autoresolve" />
    <bpmn:sequenceFlow id="edge_actioncenter-escalated" sourceRef="Activity_actioncenter" targetRef="Event_escalated" />
    <bpmn:sequenceFlow id="edge_autoresolve-resolved" sourceRef="Activity_autoresolve" targetRef="Event_resolved" />
  </bpmn:process>

  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_FieldIncidentTriage">
      <bpmndi:BPMNShape id="S_Event_start" bpmnElement="Event_start">
        <dc:Bounds x="152" y="202" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="130" y="245" width="82" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Activity_triage" bpmnElement="Activity_triage">
        <dc:Bounds x="240" y="180" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Activity_reproduce" bpmnElement="Activity_reproduce">
        <dc:Bounds x="430" y="180" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Activity_rootcause" bpmnElement="Activity_rootcause">
        <dc:Bounds x="620" y="180" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Activity_review" bpmnElement="Activity_review">
        <dc:Bounds x="810" y="180" width="140" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Activity_impact" bpmnElement="Activity_impact">
        <dc:Bounds x="1000" y="180" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Gateway_hitl" bpmnElement="Gateway_hitl" isMarkerVisible="true">
        <dc:Bounds x="1220" y="195" width="50" height="50" />
        <bpmndi:BPMNLabel><dc:Bounds x="1210" y="252" width="70" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Activity_actioncenter" bpmnElement="Activity_actioncenter">
        <dc:Bounds x="1340" y="80" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Activity_autoresolve" bpmnElement="Activity_autoresolve">
        <dc:Bounds x="1340" y="300" width="160" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Event_escalated" bpmnElement="Event_escalated">
        <dc:Bounds x="1572" y="102" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1550" y="145" width="82" height="27" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_Event_resolved" bpmnElement="Event_resolved">
        <dc:Bounds x="1572" y="322" width="36" height="36" />
        <bpmndi:BPMNLabel><dc:Bounds x="1562" y="365" width="58" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <bpmndi:BPMNEdge id="E_start-triage" bpmnElement="edge_start-triage">
        <di:waypoint x="188" y="220" /><di:waypoint x="240" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_triage-reproduce" bpmnElement="edge_triage-reproduce">
        <di:waypoint x="380" y="220" /><di:waypoint x="430" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_reproduce-rootcause" bpmnElement="edge_reproduce-rootcause">
        <di:waypoint x="570" y="220" /><di:waypoint x="620" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_rootcause-review" bpmnElement="edge_rootcause-review">
        <di:waypoint x="760" y="220" /><di:waypoint x="810" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_review-impact" bpmnElement="edge_review-impact">
        <di:waypoint x="950" y="220" /><di:waypoint x="1000" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_impact-gateway" bpmnElement="edge_impact-gateway">
        <di:waypoint x="1160" y="220" /><di:waypoint x="1220" y="220" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_gateway-actioncenter" bpmnElement="edge_gateway-actioncenter">
        <di:waypoint x="1245" y="195" /><di:waypoint x="1245" y="120" /><di:waypoint x="1340" y="120" />
        <bpmndi:BPMNLabel><dc:Bounds x="1255" y="150" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_gateway-autoresolve" bpmnElement="edge_gateway-autoresolve">
        <di:waypoint x="1245" y="245" /><di:waypoint x="1245" y="340" /><di:waypoint x="1340" y="340" />
        <bpmndi:BPMNLabel><dc:Bounds x="1255" y="290" width="60" height="14" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_actioncenter-escalated" bpmnElement="edge_actioncenter-escalated">
        <di:waypoint x="1500" y="120" /><di:waypoint x="1572" y="120" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="E_autoresolve-resolved" bpmnElement="edge_autoresolve-resolved">
        <di:waypoint x="1500" y="340" /><di:waypoint x="1572" y="340" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
